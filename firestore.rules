rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 家庭資料：限家庭成員讀寫
    // familyId == request.auth.uid 允許 owner 在尚未建立家庭文件前仍可寫入
    match /families/{familyId}/{document=**} {
      allow read, write: if request.auth != null
        && (familyId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberUids);
    }

    // 待確認佇列：寫入主要靠 Admin SDK；前端允許該家庭擁有者更新狀態或刪除
    match /unconfirmedQueue/{docId} {
      allow read:   if request.auth != null;
      allow create: if false; // 前端禁止自行新增
      allow update, delete: if request.auth != null 
        && (resource.data.familyId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.memberUids);
    }

    // 配對碼：完全封鎖前端（所有操作由 Admin SDK 執行）
    match /bindingCodes/{code} {
      allow read:  if false;
      allow write: if false;
    }

    // 冪等紀錄：完全封鎖前端（由 processLineEvents Cloud Function 寫入）
    match /families/{familyId}/processedEvents/{eventId} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
